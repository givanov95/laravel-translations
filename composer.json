{
    "name": "givanov95/laravel-translations",
    "description": "Multi-locale translation infrastructure for Laravel + Inertia + Vue projects: polymorphic Translation model, HasTranslation trait, JSON-backed Translator, locale middlewares, MultiSelect helpers.",
    "type": "library",
    "license": "MIT",
    "keywords": ["laravel", "translations", "i18n", "inertia", "vue", "multi-locale"],
    "require": {
        "php": "^8.3",
        "illuminate/contracts": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "illuminate/database": "^11.0|^12.0|^13.0",
        "illuminate/http": "^11.0|^12.0|^13.0",
        "illuminate/cache": "^11.0|^12.0|^13.0",
        "illuminate/filesystem": "^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "givanov95/laravel-git-hooks": "^1.1",
        "larastan/larastan": "^3.0",
        "orchestra/testbench": "^9.0|^10.0",
        "phpunit/phpunit": "^11.0|^12.0"
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "analyse": "vendor/bin/phpstan analyse --memory-limit=512M",
        "post-install-cmd": [
            "@php -r \"if (is_dir('.git/hooks') && file_exists('pre-commit')) { @unlink('.git/hooks/pre-commit'); @symlink('../../pre-commit', '.git/hooks/pre-commit'); @chmod('pre-commit', 0755); }\""
        ],
        "post-update-cmd": [
            "@php -r \"if (is_dir('.git/hooks') && file_exists('pre-commit')) { @unlink('.git/hooks/pre-commit'); @symlink('../../pre-commit', '.git/hooks/pre-commit'); @chmod('pre-commit', 0755); }\""
        ]
    },
    "autoload": {
        "psr-4": {
            "Givanov95\\LaravelTranslations\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Givanov95\\LaravelTranslations\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Givanov95\\LaravelTranslations\\TranslationsServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "givanov95/laravel-git-hooks": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
