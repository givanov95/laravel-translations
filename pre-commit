#!/bin/bash

# pre-commit hook for givanov95/laravel-translations
# Symlinked into .git/hooks/ by composer install/update.
# Bypass with: git commit --no-verify

RED=$(tput setaf 1 2>/dev/null || echo "")
GREEN=$(tput setaf 2 2>/dev/null || echo "")
RESET=$(tput sgr0 2>/dev/null || echo "")

# Only run if staged changes touch PHP files.
STAGED_PHP=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.php$')

if [ -z "$STAGED_PHP" ]; then
    exit 0
fi

echo "${GREEN}→ Running PHPUnit...${RESET}"
if ! vendor/bin/phpunit; then
    echo "${RED}✗ Tests failed — fix before committing (or use --no-verify).${RESET}"
    exit 1
fi

echo "${GREEN}→ Running PHPStan...${RESET}"
if ! vendor/bin/phpstan analyse --memory-limit=512M --no-progress; then
    echo "${RED}✗ Static analysis failed — fix before committing (or use --no-verify).${RESET}"
    exit 1
fi

echo "${GREEN}✓ Pre-commit checks passed.${RESET}"
exit 0
